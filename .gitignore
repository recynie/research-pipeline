# =============================================================================
# TEMPLATE-ONLY RULES — REMOVE AFTER FORKING
# =============================================================================
# The rules below keep the template repository clean by ignoring user config
# and generated content. In YOUR fork, generated content is committed by CI
# and user config IS the site — so you want these files TRACKED, not ignored.
#
# After using "Use this template":
#   1. DELETE this entire section (lines between the ===== markers)
#   2. KEEP the SHARED RULES section below
#   3. Add your own user-specific rules at the bottom (optional)
# =============================================================================

# User config (forkers: use settings.example.yaml → settings.yaml instead)
/config/settings.yaml
/config/topics.yaml

# Auto-generated Jekyll config
/_config.yml

# Generated content
/_papers/*
!/_papers/.gitkeep
/_podcasts/*
!/_podcasts/.gitkeep
/assets/audio/*
!/assets/audio/.gitkeep
/_data/summaries/*
!/_data/summaries/.gitkeep
/data/papers_index.json
/data/pdfs/
/index.md

# =============================================================================
# SHARED RULES — KEEP THESE
# =============================================================================

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
